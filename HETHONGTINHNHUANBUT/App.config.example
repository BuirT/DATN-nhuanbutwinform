<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
	</configSections>

	<connectionStrings>
		<!--
		HƯỚNG DẪN CẤU HÌNH KẾT NỐI CHO THÀNH VIÊN
		===========================================
		Hệ thống dùng SQL Server chung qua mạng Radmin VPN.

		CÁCH 1 - Kết nối đến SQL Server trung tâm (khuyên dùng):
		- Cài Radmin VPN, kết nối đến mạng chung
		- Liên hệ quản trị viên để biết IP Radmin của máy chủ SQL
		- Dùng cú pháp:
		    Server=IP_RADMIN_SERVER\SQLEXPRESS,1433;Database=Tên database;User Id=Tên người dùng;Password=mật khẩu;

		CÁCH 2 - Kết nối local (nếu tự chạy SQL trên máy mình):
		- Cài SQL Server Express (SQLEXPRESS)
		- Restore file .bak vào database Tên database
		- Dùng cú pháp:
		    Server=localhost\SQLEXPRESS;Database=Tên database;Trusted_Connection=True;

		LƯU Ý:
		- Không commit file App.config lên git (đã có trong .gitignore)
		- Chỉ sửa file App.config (KHÔNG sửa App.config.example)
		- Nếu gặp lỗi kết nối, kiểm tra:
		    1. Radmin VPN đã bật chưa?
		    2. Ping được IP máy chủ không?
		    3. Tên đăng nhập và mật khẩu SQL đúng chưa?
		-->
		<add name="TNConnection"
             connectionString="Server=IP_RADMIN_SERVER\SQLEXPRESS,1433;Database=Tên database;User Id=Tên người dùng;Password=mật khẩu;"
             providerName="System.Data.SqlClient" />
	</connectionStrings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="System.Numerics.Vectors" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-4.1.6.0" newVersion="4.1.6.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
			</dependentAssembly>
		</assemblyBinding>
	</runtime>
</configuration>
